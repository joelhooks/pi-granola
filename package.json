{
  "name": "pi-granola",
  "version": "0.1.0",
  "description": "Agent-first CLI wrapper for Granola's remote MCP server for Pi.",
  "type": "module",
  "bin": {
    "pi-granola": "./bin/pi-granola"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "check": "tsc --noEmit",
    "build": "bun build src/cli.ts --compile --outfile dist/pi-granola",
    "install-local": "bun run build && cp dist/pi-granola ~/.bun/bin/pi-granola"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
